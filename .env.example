# Environment Configuration
# Copy this file to .env and fill in the values for your environment

# Node environment (development | production)
NODE_ENV=development

# Server port
PORT=3000

# Database connection URL (PostgreSQL)
# Format: postgresql://username:password@host:port/database
# For development: postgresql://postgres:password@localhost:5432/nirmaya_db
# For production: Use a managed database service (Supabase, AWS RDS, etc.)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nirmaya_db

# JWT Configuration
# In production, this MUST be set to a strong, randomly generated secret
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=dev-jwt-secret-only-for-local-testing

# JWT token expiration time
JWT_EXPIRES_IN=7d

# CORS configuration
# Comma-separated list of allowed origins (no spaces between values)
# Examples:
#   Development: http://localhost:3000,http://localhost:3001
#   Production: https://your-domain.com,https://api.your-domain.com
CORS_ORIGIN=http://localhost:3000

# Base URL for your application
# Used for generating links, redirects, password reset links, etc.
BASE_URL=http://localhost:3000

# ========== PRODUCTION-ONLY VARIABLES ==========
# These are optional for development but recommended for production

# Error tracking service (e.g., Sentry)
# ERROR_TRACKING_DSN=https://key@sentry.io/projectid

# Logging level (debug | info | warn | error)
# LOG_LEVEL=info
